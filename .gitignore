# ============================================================
# Richgo-Cortex AI Assistant — .gitignore
# ============================================================

# --- Sensitive credentials (NEVER commit) ---
.env
*.pem
*.key
secrets.json
credentials.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.whl
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- IDE / editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Streamlit ---
.streamlit/secrets.toml

# --- Test / coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# --- Logs & temp ---
*.log
logs/
tmp/
temp/
*.tmp

# --- Snowflake output cache ---
.snowflake_cache/
query_cache/
